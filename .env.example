# ── Compose ─────────────────────────────────────────
COMPOSE_PROJECT_NAME=fitness

# ── Postgres container (admin only — NOT app credentials) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Mongo container (root admin only) ───────────────
MONGO_ROOT_USER=mongo
MONGO_ROOT_PASSWORD=mongo

# ── user-service (PostgreSQL) ───────────────────────
USER_SERVICE_DB_HOST=postgres
USER_SERVICE_DB_PORT=5432
USER_SERVICE_DB_NAME=userdb
USER_SERVICE_DB_USER=user_service
USER_SERVICE_DB_PASSWORD=change_me

# ── activity-service (MongoDB) ──────────────────────
ACTIVITY_SERVICE_MONGO_URI=mongodb://mongo:mongo@mongodb:27017/activitydb?authSource=admin
ACTIVITY_SERVICE_DB_USER=activity_service
ACTIVITY_SERVICE_DB_PASSWORD=secret_here
ACTIVITY_SERVICE_DB_NAME=activitydb

# ── ai-service (MongoDB — separate database) ────────
AI_SERVICE_MONGO_URI=mongodb://mongo:mongo@mongodb:27017/aidb?authSource=admin
AI_SERVICE_DB_USER=ai_service
AI_SERVICE_DB_PASSWORD=secret_here
AI_SERVICE_DB_NAME=aidb

# ── Eureka ──────────────────────────────────────────
EUREKA_URL=http://eureka-server:8761/eureka/

# ── Prod registry (CI) ──────────────────────────────
DOCKER_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest